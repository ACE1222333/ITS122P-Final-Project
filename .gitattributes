# Normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly LF for web files
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.php  text eol=lf
*.sql  text eol=lf
*.xml  text eol=lf
*.xsd  text eol=lf
*.dtd  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.htaccess text eol=lf

# Binary files — never touch line endings
*.jpg  binary
*.jpeg binary
*.png  binary
*.gif  binary
*.webp binary
*.ico  binary
