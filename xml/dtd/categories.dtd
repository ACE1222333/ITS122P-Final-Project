<!ELEMENT categories (category*)>

<!ELEMENT category (
  category_id,
  name,
  description?
)>

<!ELEMENT category_id  (#PCDATA)>
<!ELEMENT name         (#PCDATA)>
<!ELEMENT description  (#PCDATA)>
